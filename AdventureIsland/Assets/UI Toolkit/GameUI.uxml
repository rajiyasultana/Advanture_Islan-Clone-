    <ui:VisualElement name="root" class="hud">
        <ui:VisualElement class="left-section score-text" style="height: 50px; width: 1417px;">
            <ui:Label text="00" emoji-fallback-support="false" class="score-text" style="height: 37px; width: 295px; align-items: stretch; align-self: center; -unity-text-align: upper-right; flex-shrink: 0; font-size: 30px; -unity-font-style: bold;"/>
        </ui:VisualElement>
    </ui:VisualElement>
    <ui:VisualElement name="health-container" class="health-container" style="height: 99px; -unity-text-align: middle-left; white-space: nowrap; flex-direction: row; width: 1418px; align-items: center;">
